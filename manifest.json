            <button class="ai-send-btn" onclick="consultarAsistenteIA()"><i class="fa-solid fa-paper-plane"></i></button>
        </div>
    </div>
</div>

<script>
    let listaVentasGlobal = [];
    let listaPendientesGlobal = [];
    let ultimaLat = 0, ultimaLon = 0;

    window.onload = function() {
        setInterval(() => {
            document.getElementById('txtReloj').innerText = new Date().toLocaleTimeString('es-MX');
        }, 1000);

        if (localStorage.getItem('sesion_activa_promotor') === 'true') {
            mostrarInterfazSistema();
        }

        if(navigator.geolocation) {
            navigator.geolocation.watchPosition(p => {
                const lat = p.coords.latitude;
                const lon = p.coords.longitude;
                if(Math.abs(lat - ultimaLat) > 0.0001 || Math.abs(lon - ultimaLon) > 0.0001) {
                    ultimaLat = lat;
                    ultimaLon = lon;
                    obtenerNombreCalle(lat, lon);
                }
            }, () => {
                document.getElementById('txtGps').innerHTML = "GPS Desactivado o Sin Señal";
            });
        }

        actualizarFechasInputs();
        cargarDatosLocales();
    };

    // === REGISTRO DEL SERVICE WORKER (PWA) ===
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
            navigator.serviceWorker.register('./service-worker.js')
                .then(() => console.log('✅ PWA Service Worker registrado'))
                .catch(err => console.log('Error Service Worker:', err));
        });
    }

