    function exportarExcelTelcel() {
        const vt = listaVentasGlobal.filter(v => v.OPERADOR === 'TELCEL');
        if (vt.length === 0) return alert("Sin datos de Telcel.");

        const data = vt.map(v => ({
            "NUM. CELULA R": v["NUM. CELULAR"],
            "IMEI": v.IMEI,
            "ICCID": v.ICCID,
            "Renuevate/ Kit/Chip/ Porta": v["Renuevate/ Kit/Chip/Porta"],
            "#TIENDA / Determinant e": v["#TIENDA / Determinante"],
            "SOLO NOMBRE DE LA CADEN A": v["SOLO NOMBRE DE LA CADENA"],
            "SOLO NOMBRE DE TIENDA SIN CADENA": v["SOLO NOMBRE DE TIENDA SIN CADENA"],
            "NOMBRE COMPLETO PROMOTOR": v["NOMBRE COMPLETO PROMOTOR"],
            "FECHA DE ACTIVACIO N": v["FECHA DE ACTIVACION"],
            "MARCA": v.MARCA,
            "MODELO": v.MODELO,
            "REGISTRO": ""
        }));

        const ws = XLSX.utils.json_to_sheet(data);

        ws['!cols'] = [
            { wch: 14 }, { wch: 18 }, { wch: 22 }, { wch: 18 },
            { wch: 18 }, { wch: 14 }, { wch: 30 }, { wch: 26 },
            { wch: 16 }, { wch: 14 }, { wch: 16 }, { wch: 12 }
        ];

        const headerStyle = {
            fill: { fgColor: { rgb: "000000" } },
            font: { color: { rgb: "FFFFFF" }, bold: true },
            alignment: { textRotation: 90, vertical: "center", horizontal: "center", wrapText: true }
        };

        for (let C = 0; C < 12; C++) {
            const cellRef = XLSX.utils.encode_cell({ r: 0, c: C });
            if (ws[cellRef]) ws[cellRef].s = headerStyle;
        }

        const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "Hoja1");

        const fechaHoy = new Date().toISOString().slice(0, 10);
        XLSX.writeFile(wb, `comisiones_diarias_Omar_Telcel_${fechaHoy}.xlsx`);
    }

    function aplicarEstiloExcel(ws) { /* ... tu código ... */ }
