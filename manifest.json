<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Comisiones Omar</title>

    <!-- === PWA === -->
    <link rel="manifest" href="manifest.json">
    <meta name="theme-color" content="#001d3d">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Comisiones Omar">
    <link rel="apple-touch-icon" href="icon-192.png">

    <script src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
        body { margin:0; font-family:'Segoe UI',sans-serif; background:linear-gradient(135deg,#001d3d,#003566,#000814); min-height:100vh; color:white; padding-bottom: 90px; }
        .app { max-width:1100px; margin:auto; padding:20px; }
        
        .login-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #000814; z-index: 20000; display: flex; align-items: center; justify-content: center; padding: 20px; box-sizing: border-box; }
        .login-box { background: rgba(255, 255, 255, 0.06); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 20px; width: 100%; max-width: 420px; padding: 30px; box-shadow: 0 15px 35px rgba(0,0,0,0.8); box-sizing: border-box; text-align: center; }
        .login-box h2 { margin-top: 0; color: #ffc300; font-size: 22px; margin-bottom: 5px; }
        .login-box p { font-size: 12px; color: #aaa; margin-bottom: 25px; }
        .login-tabs { display: flex; background: rgba(0,0,0,0.4); padding: 5px; border-radius: 10px; margin-bottom: 20px; border: 1px solid rgba(255,255,255,0.05); }
        .login-tab-btn { flex: 1; padding: 10px; background: transparent; border: none; color: #aaa; font-weight: bold; font-size: 13px; cursor: pointer; border-radius: 8px; transition: 0.3s; }
        .login-tab-btn.active { background: #ffc300; color: #001d3d; }
        
        .btn-google { background: white; color: #333; width: 100%; padding: 12px; border: none; border-radius: 10px; font-weight: bold; font-size: 14px; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; box-shadow: 0 4px 10px rgba(0,0,0,0.2); transition: 0.3s; margin-bottom: 20px; }
        .btn-google:hover { background: #f1f1f1; transform: translateY(-1px); }
        .btn-google i { font-size: 18px; }
        .separator { display: flex; align-items: center; text-align: center; color: #666; font-size: 11px; margin-bottom: 20px; text-transform: uppercase; font-weight: bold; }
        .separator::before, .separator::after { content: ''; flex: 1; border-bottom: 1px solid #333; }
        .separator:not(:empty)::before { margin-right: .5em; }
        .separator:not(:empty)::after { margin-left: .5em; }

        .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; gap: 10px; }  
        .gps-card { background: #000; border: 1px solid #00b4d8; padding: 10px 15px; border-radius: 12px; color: #00b4d8; font-size: 12px; display: flex; align-items: center; max-width: 55%; }  
        .gps-card i { margin-right: 10px; font-size: 18px; color: #ffc300; min-width: 20px; }  
        .reloj-digital { font-family: monospace; font-size: 24px; color: #ffc300; font-weight: bold; display: flex; align-items: center; gap: 15px; }  
        .btn-logout { background: rgba(255, 77, 77, 0.2); border: 1px solid #ff4d4d; color: #ff4d4d; padding: 6px 12px; border-radius: 8px; font-size: 12px; cursor: pointer; font-weight: bold; transition: 0.3s; }
        .btn-logout:hover { background: #ff4d4d; color: white; }

        .main-nav { display: flex; gap: 10px; margin-bottom: 20px; background: rgba(0,0,0,0.5); padding: 8px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); flex-wrap: wrap; }
        .nav-tab-btn { flex: 1; min-width: 140px; padding: 12px; text-align: center; border-radius: 8px; font-weight: bold; cursor: pointer; border: none; background: transparent; color: white; transition: 0.3s; display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 13px; text-transform: uppercase; }
        .nav-tab-btn.active { background: #ffc300; color: #001d3d; box-shadow: 0 0 15px #ffc300; }  
  
        .menu-operadores { display: flex; gap: 10px; margin-bottom: 10px; background: rgba(255,255,255,0.05); padding: 8px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); }  
        .tab-btn { flex: 1; padding: 12px; text-align: center; border-radius: 8px; font-weight: bold; cursor: pointer; border: none; transition: 0.3s; color: white; display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 14px; }  
        .tab-telcel { background: rgba(0, 180, 216, 0.2); border: 1px solid #00b4d8; }  
        .tab-telcel.active { background: #00b4d8; color: #000; box-shadow: 0 0 15px #00b4d8; }  
        .tab-att { background: rgba(255, 114, 0, 0.2); border: 1px solid #ff7200; }  
        .tab-att.active { background: #ff7200; color: white; box-shadow: 0 0 15px #ff7200; }  
        .tab-bait { background: rgba(114, 9, 183, 0.2); border: 1px solid #7209b7; }  
        .tab-bait.active { background: #7209b7; color: white; box-shadow: 0 0 15px #7209b7; }  
  
        .sub-menu-modalidad { display: flex; gap: 10px; margin-bottom: 20px; background: rgba(0,0,0,0.4); padding: 6px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.05); }  
        .sub-tab-btn { flex: 1; padding: 8px; text-align: center; border-radius: 6px; font-size: 12px; font-weight: bold; cursor: pointer; border: none; transition: 0.2s; color: #ccc; background: transparent; }  
        .sub-tab-btn.active { background: #ffc300; color: #001d3d; box-shadow: 0 0 8px #ffc300; }  
  
        .panel-avance { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 15px; padding: 15px; margin-bottom: 15px; }  
        .panel-avance h4 { margin: 0 0 10px 0; font-size: 14px; color: #ffc300; text-transform: uppercase; }  
        .contenedor-graficas { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; }  
        .barra-progreso-item { background: rgba(0,0,0,0.3); padding: 10px; border-radius: 8px; border-left: 4px solid #fff; }  
        .info-progreso { display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 5px; font-weight: bold; }  
        .w-barra { background: rgba(255,255,255,0.1); height: 10px; border-radius: 5px; overflow: hidden; }  
        .w-relleno { height: 100%; width: 0%; transition: width 0.5s ease-in-out; }  
  
        .card { background:rgba(255,255,255,.08); backdrop-filter:blur(10px); border-radius:15px; padding:20px; margin-bottom:15px; border:1px solid rgba(255,255,255,0.1); }  
        .card h3 { margin-top: 0; margin-bottom: 15px; font-size: 16px; color: #ffc300; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 8px; display: flex; align-items: center; gap: 8px; }  
        label { font-size:10px; font-weight:bold; color:#ffc300; text-transform: uppercase; display: block; margin-bottom: 5px; }  
          
        input, select, textarea { width:100%; padding:10px; margin-bottom:10px; border-radius:8px; border:none; background:rgba(255,255,255,.12); color:white; box-sizing: border-box; outline: none; font-family: inherit; }  
        input:focus, textarea:focus { background: rgba(255,255,255,0.2); border: 1px solid #ffc300; }  
        input[type="date"]::-calendar-picker-indicator { filter: invert(1); cursor: pointer; }  
  
        .btn-save { background:#ffc300; color:#001d3d; width:100%; padding:15px; border:none; border-radius:10px; font-weight:bold; cursor:pointer; font-size: 16px; transition: 0.3s; }  
        .btn-save:active { transform: scale(0.98); }  
  
        .btn-secundario { background: #00b4d8; color: #000; font-weight: bold; padding: 12px; border: none; border-radius: 8px; cursor: pointer; width: 100%; font-size: 14px; transition: 0.3s; }  
  
        .btn-vinculo { background: #00b4d8; color: white; width: 100%; padding: 12px; border: none; border-radius: 10px; font-weight: bold; cursor: pointer; margin-top: 5px; margin-bottom: 10px; display: flex; align-items: center; justify-content: center; gap: 8px; transition: 0.3s; text-decoration: none; font-size: 14px; }  
        .btn-payjoy { background: #4a00e0; color: white; width: 100%; padding: 12px; border: none; border-radius: 10px; font-weight: bold; cursor: pointer; margin-top: 5px; margin-bottom: 15px; display: flex; align-items: center; justify-content: center; gap: 8px; transition: 0.3s; text-decoration: none; font-size: 14px; }  
          
        .descargas-container { display: flex; gap: 15px; margin-top: 20px; flex-wrap: wrap; }
        .btn-excel { flex: 1; min-width: 180px; background:#1f7a3f; color:white; padding:14px; border:none; border-radius:10px; font-weight:bold; cursor:pointer; display: flex; align-items: center; justify-content: center; gap: 10px; font-size: 14px; }  
        .btn-excel-telcel { flex: 1; min-width: 180px; background:#00509d; color:white; padding:14px; border:none; border-radius:10px; font-weight:bold; cursor:pointer; display: flex; align-items: center; justify-content: center; gap: 10px; font-size: 14px; }
        .btn-pdf { flex: 1; min-width: 180px; background:#b7094c; color:white; padding:14px; border:none; border-radius:10px; font-weight:bold; cursor:pointer; display: flex; align-items: center; justify-content: center; gap: 10px; font-size: 14px; }  
  
        .table-container { overflow-x: auto; background: white; border-radius: 10px; margin-top: 20px; margin-bottom: 30px; }  
        table { width: 100%; border-collapse: collapse; color: #333; font-size: 11px; min-width: 1100px; }  
        th { background: #000 !important; color: #fff !important; padding: 12px; text-align: left; text-transform: uppercase; font-weight: bold; border: 1px solid #444; }  
        td { padding: 10px; border: 1px solid #ddd; }  
        tr:nth-child(even) { background: #f9f9f9; }  
  
        .hidden { display: none !important; }  

        .google-ai-assistant { position: fixed; bottom: 0; left: 0; right: 0; background: rgba(10, 25, 47, 0.95); border-top: 2px solid #ffc300; backdrop-filter: blur(15px); padding: 10px 20px; z-index: 10000; box-shadow: 0 -5px 25px rgba(0,0,0,0.5); box-sizing: border-box; }
        .ai-bar-layout { display: flex; align-items: center; gap: 12px; max-width: 1100px; margin: auto; }
        .ai-logo-container { width: 35px; height: 35px; background: linear-gradient(135deg, #4285F4, #EA4335, #FBBC05, #4285F4); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .ai-logo-container i { color: white; font-size: 16px; }
        .ai-input-wrapper { flex-grow: 1; position: relative; display: flex; align-items: center; }
        .ai-input-wrapper input { width: 100%; padding: 12px 50px 12px 15px; margin: 0; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 30px; color: white; font-size: 14px; outline: none; }
        .ai-send-btn { position: absolute; right: 8px; background: #ffc300; color: #001d3d; border: none; width: 36px; height: 36px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 16px; }
        
        .ai-response-dropdown { position: absolute; bottom: 70px; left: 20px; right: 20px; max-width: 1060px; margin: auto; background: #001d3d; border: 1px solid #ffc300; border-radius: 12px; max-height: 320px; overflow-y: auto; padding: 15px; box-shadow: 0 -10px 30px rgba(0,0,0,0.6); display: none; }
        .ai-response-dropdown h4 { margin: 0 0 10px 0; font-size: 13px; color: #ffc300; display: flex; align-items: center; gap: 8px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 5px; }
        .ai-response-text { font-size: 13px; line-height: 1.5; color: #e0e0e0; white-space: pre-line; }
        .close-ai-dropdown { float: right; cursor: pointer; color: #ff4d4d; font-size: 14px; }
    </style>
</head>
<body>

<!-- LOGIN -->
<div class="login-overlay" id="seccionLogin">
    <div class="login-box">
        <h2>SISTEMA DE CONTROL</h2>
        <p>Inicia sesión para acceder a tus registros locales</p>
        
        <div class="login-tabs">
            <button id="tabOpLogin" class="login-tab-btn active" onclick="alternarFormularioAcceso('LOGIN')">Entrar</button>
            <button id="tabOpRegistro" class="login-tab-btn" onclick="alternarFormularioAcceso('REGISTRO')">Nuevo Correo</button>
        </div>

        <button class="btn-google" onclick="ejecutarLoginGoogle()">
            <i class="fa-brands fa-google" style="color: #4285F4;"></i> Iniciar sesión con Google
        </button>

        <div class="separator">O con tu cuenta</div>

        <form id="fAcceso" onsubmit="procesarAutenticacion(event)">
            <input type="hidden" id="tipoAccesoActual" value="LOGIN">
            <input type="email" id="logEmail" placeholder="Correo electrónico (ej: omar@gmail.com)" required>
            <input type="password" id="logPass" placeholder="Contraseña" required>
            <button type="submit" id="btnAccesoAccion" class="btn-save" style="padding: 12px; font-size:14px;">INGRESAR AL PANEL</button>
        </form>
    </div>
</div>

<!-- SISTEMA PRINCIPAL -->
<div class="app hidden" id="wrapperSistema">  
    <div class="top-bar">  
        <div class="gps-card">  
            <i class="fa-solid fa-location-dot"></i>  
            <div><b style="color:white">UBICACIÓN ACTUAL</b><br><span id="txtGps">Localizando...</span></div>  
        </div>  
        <div class="reloj-digital">
            <span id="txtReloj">00:00:00</span>
            <button class="btn-logout" onclick="cerrarSesionSistema()"><i class="fa-solid fa-power-off"></i> Salir</button>
        </div>  
    </div>  

    <div class="main-nav">
        <button id="navVentas" class="nav-tab-btn active" onclick="cambiarSeccionPrincipal('VENTAS')"><i class="fa-solid fa-cash-register"></i> Panel Ventas</button>
    </div>

    <div id="seccionVentas">
        <!-- Panel de Avance -->
        <div class="panel-avance">  
            <h4><i class="fa-solid fa-chart-line"></i> Gráfica de Avance de Ventas Diarias</h4>  
            <div class="contenedor-graficas">  
                <div class="barra-progreso-item" style="border-left-color: #00b4d8;">  
                    <div class="info-progreso"><span>TELCEL</span><span id="lblTelcel">0</span></div>  
                    <div class="w-barra"><div id="barTelcel" class="w-relleno" style="background:#00b4d8;"></div></div>  
                </div>  
                <div class="barra-progreso-item" style="border-left-color: #ff7200;">  
                    <div class="info-progreso"><span>AT&T</span><span id="lblAtt">0</span></div>  
                    <div class="w-barra"><div id="barAtt" class="w-relleno" style="background:#ff7200;"></div></div>  
                </div>  
                <div class="barra-progreso-item" style="border-left-color: #7209b7;">  
                    <div class="info-progreso"><span>BAIT</span><span id="lblBait">0</span></div>  
                    <div class="w-barra"><div id="barBait" class="w-relleno" style="background:#7209b7;"></div></div>  
                </div>  
            </div>  
        </div>  

        <!-- Menú Operadores -->
        <div class="menu-operadores">  
            <button class="tab-btn tab-telcel active" onclick="cambiarOperador('TELCEL')"><i class="fa-solid fa-phone"></i> TELCEL</button>  
            <button class="tab-btn tab-att" onclick="cambiarOperador('AT&T')"><i class="fa-solid fa-signal"></i> AT&T</button>  
            <button class="tab-btn tab-bait" onclick="cambiarOperador('BAIT')"><i class="fa-solid fa-bolt"></i> BAIT</button>  
        </div>  

        <div id="wrapperSubModalidad" class="sub-menu-modalidad hidden">  
            <button id="subTabLinea" class="sub-tab-btn active" onclick="cambiarModalidad('LINEA')"><i class="fa-solid fa-sim-card"></i> LÍNEA CON EQUIPO</button>  
            <button id="subTabSoloTelo" class="sub-tab-btn" onclick="cambiarModalidad('SOLO_TELO')"><i class="fa-solid fa-mobile-screen"></i> SOLO SE VENDIÓ TELÉFONO</button>  
        </div>  

        <!-- Formulario de Venta -->
        <form id="fReg" onsubmit="guardarVentaLocal(event)">  
            <input type="hidden" id="iOperador" value="TELCEL">  
            <input type="hidden" id="iModalidadVenta" value="LINEA">  
              
            <div class="card">  
                <div id="wrapperVinculo">  
                    <label>VINCULACIÓN OBLIGATORIA</label>  
                    <a href="https://registro.telcel.com/vinculatulinea/#/" target="_blank" class="btn-vinculo">  
                        <i class="fa-solid fa-link"></i> ABRIR REGISTRO / VINCULA TU LÍNEA  
                    </a>  
                </div>  
      
                <div id="wrapperPayJoy">  
                    <label>FINANCIAMIENTO DE EQUIPOS</label>  
                    <a href="https://app.payjoy.com/accounts/login?afterLogin=https://app.payjoy.com/merchant3?merchantId=199557" target="_blank" class="btn-payjoy">  
                        <i class="fa-solid fa-hand-holding-dollar"></i> PLATAFORMA PAYJOY  
                    </a>  
                </div>  
      
                <div id="wrapperTipo">  
                    <label>Renuevate/ Kit/Chip/Porta</label>  
                    <select id="iTipo">  
                        <option value="KIT">KIT</option>  
                        <option value="CHIP">CHIP</option>  
                        <option value="PORTA">PORTA</option>  
                        <option value="RENUEVATE">RENUEVATE</option>  
                    </select>  
                </div>  
                  
                <label>FECHA DE ACTIVACION / VENTA (MODIFICABLE)</label>  
                <input id="iFec" type="date" required style="color: #ffc300;">  
                  
                <div id="wrapperTel">  
                    <label>NUM. CELULAR (10 DÍGITOS)</label>  
                    <input id="iTel" type="tel" required maxlength="10" placeholder="Ej. 5512345678">  
                </div>  
                  
                <div id="wrapperIcc">  
                    <label>ICCID (ÚLTIMOS DÍGITOS)</label>  
                    <input id="iIcc" required placeholder="Ingresa el ICCID">  
                </div>  
            </div>  

            <div class="card">  
                <div id="wrapperImei"><label>IMEI</label><input id="iIme" placeholder="IMEI del equipo"></div>  
                <label>MARCA</label><input id="iMarca" required placeholder="Ej. Samsung">  
                <label>MODELO</label><input id="iMod" required placeholder="Ej. Galaxy A54">  
                <label>UPC / CÓDIGO BARRAS (OPCIONAL)</label><input id="iUpc" placeholder="Código de barras del equipo">  
            </div>  

            <div class="card">  
                <label>#TIENDA / Determinante</label><input id="iTiendaNum" required placeholder="Número de tienda">  
                <label>SOLO NOMBRE DE LA CADENA</label><input id="iCadena" required placeholder="Ej. Coppel / Elektra">  
                <label>SOLO NOMBRE DE TIENDA SIN CADENA</label><input id="iTiendaNombre" required placeholder="Ej. Plaza Aragón">  
                <label>NOMBRE COMPLETO PROMOTOR</label><input id="iProm" required placeholder="Tu nombre">  
            </div>  
                
            <button type="submit" id="btnGuardar" class="btn-save">GUARDAR VENTA LOCALMENTE</button>  
        </form>  

        <!-- Botones de Exportar -->
        <div class="descargas-container">
            <button class="btn-excel" onclick="exportarExcelGeneral()">  
                <i class="fa-solid fa-file-excel"></i> REPORTE GENERAL (TODOS)
            </button>  
            <button class="btn-excel-telcel" onclick="exportarExcelTelcel()">  
                <i class="fa-solid fa-file-excel"></i> EXCEL SOLO TELCEL  
            </button>  
            <button class="btn-pdf" onclick="exportarPDF()">  
                <i class="fa-solid fa-file-pdf"></i> REPORTE PDF  
            </button>  
        </div>  

        <!-- Tabla de Ventas -->
        <div class="table-container" id="tablaVentasContenedor">  
            <table id="tablaVentasReal">  
                <thead>  
                    <tr>  
                        <th>OPERADOR</th>  
                        <th>NUM. CELULAR</th>  
                        <th>IMEI</th>  
                        <th>ICCID</th>  
                        <th>TIPO</th>  
                        <th>#TIENDA</th>  
                        <th>CADENA</th>  
                        <th>TIENDA</th>  
                        <th>PROMOTOR</th>  
                        <th>FECHA</th>  
                        <th>MARCA</th>  
                        <th>MODELO</th>  
                        <th style="background:red !important; text-align: center; width: 50px;">X</th>  
                    </tr>  
                </thead>  
                <tbody id="bodyVentas"></tbody>  
            </table>  
        </div>  

        <!-- Sección de Pendientes -->
        <div class="card" style="margin-top: 40px; border: 1px solid #ff4d4d; background: rgba(255, 77, 77, 0.05);">  
            <h3><i class="fa-solid fa-clock-rotate-left" style="color: #ff4d4d;"></i> IMEIS / ACTIVACIONES PENDIENTES</h3>  
            <form id="fPendientes" onsubmit="guardarPendienteLocal(event)">  
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px;">  
                    <div><label>FECHA PENDIENTE</label><input id="pFec" type="date" required style="color: #ff4d4d;"></div>  
                    <div><label>MARCA</label><input id="pMarca" required placeholder="Ej. Motorola"></div>  
                    <div><label>MODELO</label><input id="pMod" required placeholder="Ej. Moto G54"></div>  
                    <div><label>IMEI</label><input id="pImei" required placeholder="IMEI"></div>  
                    <div><label>ICCID</label><input id="pIccid" required placeholder="ICCID"></div>  
                    <div><label>NÚMERO</label><input id="pNum" type="tel" required maxlength="10" placeholder="10 dígitos"></div>  
                </div>  
                <button type="submit" class="btn-secundario" style="background: #ff4d4d; color: white; margin-top: 10px; border:none; padding:12px; border-radius:8px; font-weight:bold; width:100%; cursor:pointer;">  
                    <i class="fa-solid fa-plus"></i> AGREGAR A PENDIENTES  
                </button>  
            </form>  
        </div>  

        <div class="table-container" style="border: 1px solid #ff4d4d;">  
            <table>  
                <thead>  
                    <tr>  
                        <th style="background: #ff4d4d !important; color: white !important;">FECHA PENDIENTE</th>  
                        <th style="background: #ff4d4d !important; color: white !important;">MARCA</th>  
                        <th style="background: #ff4d4d !important; color: white !important;">MODELO</th>  
                        <th style="background: #ff4d4d !important; color: white !important;">IMEI</th>  
